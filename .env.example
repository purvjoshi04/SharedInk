# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sharedink
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sharedink

# Backend Configuration
PORT=3001
JWT_SECRET="YOUR SECRET"
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# CORS & Service URLs (Internal Docker Network)
FRONTEND_URL=http://localhost:3000
WS_BACKEND_URL=http://ws-backend:3002

# Frontend Environment Variables (External - for browser)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3002
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_SECRET=
AUTH_TRUST_HOST=true